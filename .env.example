# Copy this file to .env (or .env.local) and only fill what you actually need.

# --------------------------------------------------------------------
# Minimal required config: choose one provider
# --------------------------------------------------------------------

# OpenAI
OPENAI_API_KEY=

# Azure OpenAI
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# OPENAI_API_VERSION=

# Optional if you use an OpenAI-compatible gateway
# OPENAI_BASE_URL=

# Optional: sandbox network access for downloads inside Docker.
# If set, these are forwarded into the sandbox and final validation container.
# HTTP_PROXY=
# HTTPS_PROXY=
# NO_PROXY=
# http_proxy=
# https_proxy=
# no_proxy=

# Optional: Hugging Face access for gated models or datasets inside Docker.
# HF_TOKEN=

# --------------------------------------------------------------------
# Common optional runtime config
# --------------------------------------------------------------------

# Where jobs/, exports/, and .aisci/ state are written.
# Default: the current repo root.
# AISCI_OUTPUT_ROOT=/abs/path/to/aisci-runtime

# Main paper loop tuning. Most users can leave these alone.
# AISCI_MAX_STEPS=80
# AISCI_REMINDER_FREQ=5

# Optional: point to a custom LLM profile registry YAML.
# Default: <repo>/config/llm_profiles.yaml
# AISCI_LLM_PROFILE_FILE=/abs/path/to/llm_profiles.yaml

# Optional: point to a custom runtime image profile YAML.
# Default: <repo>/config/image_profiles.yaml
# AISCI_IMAGE_PROFILE_FILE=/abs/path/to/image_profiles.yaml

# Model selection is not configured here.
# Pick it at runtime with `--llm-profile gpt-5.4` or `--llm-profile glm-5`.

# --------------------------------------------------------------------
# Advanced / usually not needed
# --------------------------------------------------------------------

# Only needed when the command is launched outside the repo and the codebase
# cannot infer where AiScientist's docker/ and src/ assets live.
# AISCI_REPO_ROOT=/abs/path/to/AiScientist

# Debugging / diagnostics
# AISCI_PAPER_DOCTOR_PROFILE=gpt-5.4
# AISCI_WEB_SEARCH=true
